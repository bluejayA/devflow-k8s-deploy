apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name }}
  namespace: {{ namespace }}
spec:
  replicas: {{ replicas }}
  selector:
    matchLabels:
      app: {{ app_name }}
  template:
    metadata:
      labels:
        app: {{ app_name }}
    spec:
      serviceAccountName: {{ app_name }}-sa
      # 기본 토큰 자동 마운트 차단 — RBAC 최소권한
      automountServiceAccountToken: false
      # Pod securityContext — 컨테이너 권한 분리 — privileged escalation 방지 (F-31)
      securityContext:
        runAsNonRoot: true
        runAsUser: {{ run_as_user }}
        runAsGroup: {{ run_as_user }}
        fsGroup: {{ run_as_user }}
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: {{ app_name }}
          image: {{ image }}
          # imagePullPolicy 명시 — non-mutable tag 전제(동일 태그 재사용 금지).
          # 공급망 방어 강화: CI/CD에서 digest(`image@sha256:...`) pinning 권장.
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: {{ port }}
          # Container securityContext — 컨테이너 권한 분리 — privileged escalation 방지 (F-32)
          securityContext:
            readOnlyRootFilesystem: true
            allowPrivilegeEscalation: false
            privileged: false
            capabilities:
              drop:
                - ALL
          # 리소스 한도 — OOMKill로 다른 Pod 영향 방지 (F-33)
          resources:
            requests:
              cpu: {{ cpu_request }}
              memory: {{ memory_request }}
            limits:
              cpu: {{ cpu_limit }}
              memory: {{ memory_limit }}
          # 프로브 — 헬스체크 — 비정상 인스턴스 자동 제거 (F-34)
          livenessProbe:
            {% if liveness_http %}
            httpGet:
              path: {{ liveness_http.path }}
              port: {{ liveness_http.port }}
            {% else %}
            tcpSocket:
              port: {{ liveness_tcp_port }}
            {% endif %}
            initialDelaySeconds: 10
            periodSeconds: 10
          readinessProbe:
            {% if readiness_http %}
            httpGet:
              path: {{ readiness_http.path }}
              port: {{ readiness_http.port }}
            {% else %}
            tcpSocket:
              port: {{ readiness_tcp_port }}
            {% endif %}
            initialDelaySeconds: 5
            periodSeconds: 5
          # emptyDir 마운트 — readOnlyRootFilesystem 공존 + 런타임 쓰기 경로 (F-32, 스택별 컨벤션)
          volumeMounts:
{% for vm in writable_volume_mounts %}
            - name: {{ vm.name }}
              mountPath: {{ vm.mount_path }}
{% endfor %}
      volumes:
{% for v in writable_volumes %}
        - name: {{ v.name }}
          # {{ v.comment }}
          emptyDir:
            sizeLimit: {{ v.size_limit }}
{% endfor %}
