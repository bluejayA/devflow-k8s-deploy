apiVersion: apps/v1
kind: Deployment
metadata:
  name: {{ app_name }}
  namespace: {{ namespace }}
spec:
  replicas: {{ replicas }}
  selector:
    matchLabels:
      app: {{ app_name }}
  template:
    metadata:
      labels:
        app: {{ app_name }}
    spec:
      serviceAccountName: {{ app_name }}-sa
      # 기본 토큰 자동 마운트 차단 — RBAC 최소권한
      automountServiceAccountToken: false
      # Pod securityContext — 컨테이너 권한 분리 — privileged escalation 방지 (F-31)
      securityContext:
        runAsNonRoot: true
        runAsUser: 1000
        runAsGroup: 1000
        fsGroup: 1000
        seccompProfile:
          type: RuntimeDefault
      containers:
        - name: {{ app_name }}
          image: {{ image }}
          # imagePullPolicy 명시 — tag mutation 재푸시 시 갱신 보장 (F-공급망)
          imagePullPolicy: IfNotPresent
          ports:
            - name: http
              containerPort: {{ port }}
          # Container securityContext — 컨테이너 권한 분리 — privileged escalation 방지 (F-32)
          securityContext:
            readOnlyRootFilesystem: true
            allowPrivilegeEscalation: false
            privileged: false
            capabilities:
              drop:
                - ALL
          # 리소스 한도 — OOMKill로 다른 Pod 영향 방지 (F-33)
          resources:
            requests:
              cpu: {{ cpu_request }}
              memory: {{ memory_request }}
            limits:
              cpu: {{ cpu_limit }}
              memory: {{ memory_limit }}
          # 프로브 — 헬스체크 — 비정상 인스턴스 자동 제거 (F-34)
          livenessProbe:
            {% if liveness_http %}
            httpGet:
              path: {{ liveness_http.path }}
              port: {{ liveness_http.port }}
            {% else %}
            tcpSocket:
              port: {{ liveness_tcp_port }}
            {% endif %}
            initialDelaySeconds: 10
            periodSeconds: 10
          readinessProbe:
            {% if readiness_http %}
            httpGet:
              path: {{ readiness_http.path }}
              port: {{ readiness_http.port }}
            {% else %}
            tcpSocket:
              port: {{ readiness_tcp_port }}
            {% endif %}
            initialDelaySeconds: 5
            periodSeconds: 5
          # emptyDir 마운트 — readOnlyRootFilesystem 공존 + JVM 런타임 쓰기 경로 (F-32)
          volumeMounts:
            - name: tmp
              mountPath: /tmp
            - name: var-log
              mountPath: /var/log
      volumes:
        - name: tmp
          # DoS 방어 — 노드 디스크 소진 방지 (Tomcat work dir, JVM temp files)
          emptyDir:
            sizeLimit: 50Mi
        - name: var-log
          # DoS 방어 + Spring Boot 런타임 로그 경로
          emptyDir:
            sizeLimit: 100Mi
